# Jira configuration
# Replace the required placeholders before starting the service. src/config.py
# rejects empty values and known example placeholders for the Jira URL,
# credentials, project key, webhook secret, and metrics token.
JIRA_URL=https://your-domain.atlassian.net
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=ENG
JIRA_EMAIL=your-email@domain.com

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# Required in production. Provide trusted owner/repo values; src/config.py
# validates the format but cannot infer your intended repositories.
ALLOWED_GITHUB_REPOS=octo-org/example-repo

# Metrics protection
METRICS_TOKEN=your_metrics_token_here

# Service
# Use FLASK_ENV=development only for local lab work. Production fails closed
# when ALLOWED_GITHUB_REPOS is empty or missing.
FLASK_ENV=production
# Safe default binds to loopback only. Set APP_HOST=0.0.0.0 only when you
# intentionally expose the service behind a reverse proxy or tightly scoped
# network controls.
APP_HOST=127.0.0.1
APP_PORT=5000

# Optional health metadata override.
VERSION=1.0.0
